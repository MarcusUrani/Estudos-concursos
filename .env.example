# Copie para .env e preencha

# --- Banco de dados ---
# Desenvolvimento (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Producao (PostgreSQL — ex.: Neon). Troque tambem o `provider` em
# prisma/schema.prisma para "postgresql". Exemplo de URL do Neon:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Gere com: npx auth secret
AUTH_SECRET="gere com: npx auth secret"
# Necessario fora da Vercel / atras de proxy:
AUTH_TRUST_HOST="true"

# --- Feedback por e-mail (Mailgun) ---
# Necessario para o envio de sugestoes/erros da plataforma.
MAILGUN_API_KEY="sua-chave-privada-do-mailgun"
MAILGUN_DOMAIN="sandboxXXXX.mailgun.org"   # ou seu dominio verificado
# FEEDBACK_TO="destino@exemplo.com"         # padrao: marcus.urani20@gmail.com
# MAILGUN_FROM="Estuda SEDES-DF <postmaster@SEU_DOMINIO>"
# MAILGUN_BASE_URL="https://api.eu.mailgun.net"  # use se a conta for da regiao EU

# --- Seed (opcional) ---
# Senha do usuario inicial ao CRIAR (db:reset / banco novo). Em re-seeds que
# mantem o usuario, a senha atual e preservada. Use aspas simples se houver
# caracteres especiais. Padrao: estudar123
# SEED_USER_PASSWORD='sua-senha-forte'
